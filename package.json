{
  "name": "@elumeo/jfs-core",
  "version": "11.0.0-alpha.3",
  "description": "Foundation for all JFS Apps",
  "main": "Main.js",
  "directories": {
    "bin": "./scripts/bin"
  },
  "scripts": {
    "start": "webpack serve --port 8083 --config build-tools/webpack/dev-server",
    "build": "tsc && tsc-alias",
    "build:watch": "tsc-watch --onSuccess tsc-alias",
    "build:webpack": "webpack --config build-tools/webpack/dev-server",
    "release": "npm publish --access public",
    "release:alpha": "npm publish --tag alpha --access public",
    "release:beta": "npm publish --tag beta --access public",
    "install:subpkg": "subpkg install",
    "postinstall": "npm run install:subpkg && npm run jfs-postinstall",
    "clean-install": "rm -rf ./node_modules ./package-lock.json && npm i",
    "jfs-check-api": "node ./scripts/bin/jfs-check-api",
    "jfs-check-translations": "node ./scripts/bin/jfs-check-translations",
    "jfs-read-translations": "node ./scripts/bin/jfs-read-translations",
    "jfs-deploy-config-files": "node ./scripts/bin/jfs-deploy-config-files",
    "jfs-generate-api": "node ./scripts/bin/jfs-generate-api",
    "jfs-open-showcase": "node ./scripts/bin/jfs-open-showcase",
    "jfs-postinstall": "node ./scripts/bin/jfs-postinstall",
    "jfs-check-config-schema": "node ./scripts/bin/jfs-check-config-schema"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elumeo/jfs-core.git"
  },
  "author": "elumeo SE",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/elumeo/jfs-core/issues"
  },
  "homepage": "http://www.elumeo.com",
  "subPackages": [
    "scripts"
  ],
